# ──────────────────────────────────────────
# AI Prompt Governance Platform – Environment
# Copy to .env and fill in your values
# ──────────────────────────────────────────

# Application
APP_NAME="AI Governance Platform"
APP_VERSION="1.0.0"
DEBUG=false

# Database (SQLite – default for local/PoC; swap for PostgreSQL+asyncpg in production)
DATABASE_URL=sqlite+aiosqlite:///./governance.db

# JWT Authentication  (change SECRET_KEY in production!)
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM Provider: Groq ────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Available models: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768 | gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Governance Thresholds
RISK_BLOCK_THRESHOLD=80
RISK_WARN_THRESHOLD=50
KNOWLEDGE_SHIELD_THRESHOLD=0.75

# Embeddings (optional – needed for Knowledge Shield)
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=data/faiss_index

# CORS (comma-separated frontend origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
